# Anthropic API 키 (fake 데모에서는 비워둔다)
ANTHROPIC_API_KEY=

# 지식베이스 디렉토리 — 이 값만 바꾸면 다른 분야 챗봇으로 전환된다
KNOWLEDGE_DIR=knowledge

# 사용할 모델
# - auto: codex-cli:gpt-5.4 -> claude-cli -> fake 순서로 시도
# - fake: API 호출 없는 결정론 데모
# - claude-cli: 로컬 Claude CLI
# - codex-cli 또는 codex-cli:gpt-5.4: Codex CLI 실응답
MODEL=auto
CODEX_MODEL=gpt-5.4
# auto 모드 순서. 비워두면 codex-cli:${CODEX_MODEL} -> claude-cli -> fake
MODEL_CHAIN=codex-cli:gpt-5.4,claude-cli,fake

# 리버스 프록시 hop 수 (X-Forwarded-For 신뢰 범위, rate limit에 사용)
TRUST_PROXY_HOPS=0

# 하루 최대 요청 수 캡
DAILY_REQUEST_CAP=500

# 관리자 통계 API 인증 토큰 — 비워두면 /api/stats는 fail-closed(503)
STATS_API_TOKEN=
